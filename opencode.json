{
  "$schema": "https://opencode.ai/config.json",
  "instructions": ["AGENTS.md"],
  "provider": {
    "openai-compat": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "OpenAI Compatible",
      "options": {
        "baseURL": "{env:OPENAI_COMPAT_BASE_URL}",
        "apiKey": "{env:OPENAI_COMPAT_API_KEY}"
      },
      "models": {
        "{env:OPENAI_COMPAT_MODEL}": {
          "name": "Review Model",
          "limit": {
            "context": 128000,
            "output": 64000
          }
        }
      }
    }
  },
  "watcher": {
    "ignore": ["docs/**", ".git/**", "__pycache__/**", "*.pyc"]
  },
  "agent": {},
  "command": {
    "dev": {
      "template": "Start the WebComPy development server. Run `uv run python -m webcompy start --dev` from the project root (default port 8080). The server serves the docs_app app at http://localhost:8080/.",
      "description": "Start dev server"
    },
    "generate-docs": {
      "template": "Generate the static documentation site from docs_app/ using `python -m webcompy generate`",
      "description": "Generate docs site"
    }
  }
}